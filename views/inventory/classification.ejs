<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= classificationName %> Vehicles</title>
<link rel="stylesheet" href="/css/styles.css">
  
</head>
<body>
  <main>
    <h1><%= classificationName %> Vehicles</h1>

    <!-- Flash message -->
    <% if (flashMessage && flashMessage.length > 0) { %>
      <p style="color: green;"><%= flashMessage %></p>
    <% } %>

    <!-- Vehicle grid or "no vehicles" message -->
    <%- grid %>
    
  </main>
</body>
</html>