<h1>Edit Vehicle</h1>
<% if (flashMessage && flashMessage.length) { %><div class="flash-message"><%= flashMessage[0] %></div><% } %>
<% if (errors && errors.length) { %><ul class="error-list"><% errors.forEach(e => { %><li><%= e.msg %></li><% }); %></ul><% } %>

<form action="/inv/edit-vehicle/<%= vehicle.inv_id %>" method="POST" id="editForm">
  <input type="hidden" name="inv_id" value="<%= vehicle.inv_id %>">
  <label>Make:</label> <input type="text" name="inv_make" value="<%= vehicle.inv_make %>" required>
  <label>Model:</label> <input type="text" name="inv_model" value="<%= vehicle.inv_model %>" required>
  <label>Year:</label> <input type="number" name="inv_year" value="<%= vehicle.inv_year %>" required min="1900" max="2026">
  <label>Description:</label> <textarea name="inv_description" required><%= vehicle.inv_description %></textarea>
  <label>Image URL:</label> <input type="url" name="inv_image" value="<%= vehicle.inv_image %>">
  <label>Thumbnail URL:</label> <input type="url" name="inv_thumbnail" value="<%= vehicle.inv_thumbnail %>">
  <label>Price:</label> <input type="number" step="0.01" name="inv_price" value="<%= vehicle.inv_price %>" required>
  <label>Miles:</label> <input type="number" name="inv_miles" value="<%= vehicle.inv_miles %>" required>
  <label>Color:</label> <input type="text" name="inv_color" value="<%= vehicle.inv_color %>" required>
  <label>Classification:</label>
  <select name="classification_id" required>
    <option value="">Select</option>
    <% classifications.forEach(c => { %>
      <option value="<%= c.classification_id %>" <%= (vehicle.classification_id == c.classification_id) ? 'selected' : '' %>><%= c.classification_name %></option>
    <% }); %>
  </select>
  <button type="submit">Update Vehicle</button>
</form>
<script>
  document.getElementById('editForm').addEventListener('submit', function(e) {
    const price = parseFloat(this.inv_price.value);
    const miles = parseInt(this.inv_miles.value);
    if (isNaN(price) || price < 0) { alert("Price must be a positive number."); e.preventDefault(); }
    else if (isNaN(miles) || miles < 0) { alert("Miles must be a non-negative integer."); e.preventDefault(); }
  });
</script>