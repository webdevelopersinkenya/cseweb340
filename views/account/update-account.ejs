<h1>Update Account</h1>

<!-- Flash messages -->
<% if (notice && notice.length) { %>
  <div class="flash-message notice"><%= notice[0] %></div>
<% } %>
<% if (error && error.length) { %>
  <div class="flash-message error"><%= error[0] %></div>
<% } %>

<!-- Server‑side validation errors -->
<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }); %>
  </ul>
<% } %>

<!-- Form 1: Update account info -->
<h2>Account Update</h2>
<form action="/account/update" method="POST">
  <input type="hidden" name="account_id" value="<%= account.account_id %>">

  <label for="account_firstname">First Name:</label>
  <input type="text" name="account_firstname" id="account_firstname" required
         value="<%= account.account_firstname %>">

  <label for="account_lastname">Last Name:</label>
  <input type="text" name="account_lastname" id="account_lastname" required
         value="<%= account.account_lastname %>">

  <label for="account_email">Email:</label>
  <input type="email" name="account_email" id="account_email" required
         value="<%= account.account_email %>">

  <button type="submit">Update Information</button>
</form>

<hr>

<!-- Form 2: Change password -->
<h2>Change Password</h2>
<form action="/account/updatePassword" method="POST">
  <input type="hidden" name="account_id" value="<%= account.account_id %>">

  <label for="account_password">New Password:</label>
  <div class="password-requirements">
    Password must be at least 12 characters, contain 1 uppercase, 1 number, and 1 special character.
  </div>
  <input type="password" name="account_password" id="account_password" required
         pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$"
         title="Password must be at least 12 characters with 1 number, 1 uppercase, and 1 special character">

  <label for="account_password_confirm">Confirm New Password:</label>
  <input type="password" name="account_password_confirm" id="account_password_confirm" required>

  <button type="submit">Change Password</button>
</form>